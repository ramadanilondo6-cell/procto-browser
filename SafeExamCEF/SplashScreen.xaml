<Window x:Class="Procto.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading Procto..." Height="300" Width="520"
        WindowStyle="None" WindowStartupLocation="CenterScreen"
        Background="Transparent" AllowsTransparency="True" Topmost="True">
    <Border Background="#1e1e2e" CornerRadius="12" BorderBrush="#4a90d9" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo: Shield SVG + Title (no ICO reference) -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="72" Height="72" Background="#4a90d9" CornerRadius="16" Margin="0,0,0,16">
                    <Viewbox Width="44" Height="44">
                        <Path Fill="White"
                              Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M10,17L6,13L7.41,11.59L10,14.17L16.59,7.58L18,9L10,17Z"/>
                    </Viewbox>
                </Border>
                <TextBlock Text="Procto" Foreground="White" FontSize="32" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="Secure Exam Environment" Foreground="#aaaacc" FontSize="13"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Status -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                <Viewbox Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Path Fill="#4a90d9"
                          Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"/>
                </Viewbox>
                <TextBlock x:Name="StatusText" Text="Memulai sistem..."
                           Foreground="#4a90d9" FontSize="14" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Progress Bar -->
            <Border Grid.Row="2" Height="6" Background="#2d2d3a" CornerRadius="3" ClipToBounds="True">
                <ProgressBar x:Name="LoadingProgress" Minimum="0" Maximum="100" Value="0"
                             Background="Transparent" Foreground="#4a90d9" BorderThickness="0"/>
            </Border>
        </Grid>
    </Border>
</Window>
